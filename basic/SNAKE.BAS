10 SCREEN 13
20 DIM SX(200)
30 DIM SY(200)
40 LET CS=8
50 LET GW=40
60 LET GH=25
70 LET LN=5
80 LET DX=1
90 LET DY=0
100 FOR I=0 TO LN-1
110 LET SX(I)=20-I
120 LET SY(I)=12
130 NEXT I
140 LET FX=30
150 LET FY=12
160 LET SC=0
170 GCLS 0

200 LET PX0=FX*CS
210 LET PY0=FY*CS
220 FOR Y=PY0 TO PY0+CS-1
230 FOR X=PX0 TO PX0+CS-1
240 PSET X,Y,12
250 NEXT X
260 NEXT Y

300 LET PX0=SX(0)*CS
310 LET PY0=SY(0)*CS
320 FOR Y=PY0 TO PY0+CS-1
330 FOR X=PX0 TO PX0+CS-1
340 PSET X,Y,10
350 NEXT X
360 NEXT Y

400 FOR W=1 TO 3000
410 NEXT W

450 LET K$=INKEY$
460 LET K=ASC(K$)
470 IF K=0 THEN GOTO 600
480 IF K=113 THEN GOTO 900
490 IF K=97 THEN LET DX=-1
495 IF K=97 THEN LET DY=0
500 IF K=100 THEN LET DX=1
505 IF K=100 THEN LET DY=0
510 IF K=119 THEN LET DX=0
515 IF K=119 THEN LET DY=-1
520 IF K=115 THEN LET DX=0
525 IF K=115 THEN LET DY=1

600 LET PX0=SX(LN-1)*CS
610 LET PY0=SY(LN-1)*CS
620 FOR Y=PY0 TO PY0+CS-1
630 FOR X=PX0 TO PX0+CS-1
640 PSET X,Y,0
650 NEXT X
660 NEXT Y

700 LET NX=SX(0)+DX
710 LET NY=SY(0)+DY
720 IF NX<0 THEN GOTO 900
730 IF NX>=GW THEN GOTO 900
740 IF NY<0 THEN GOTO 900
750 IF NY>=GH THEN GOTO 900

760 LET GR=0
770 IF NX=FX THEN IF NY=FY THEN LET GR=1

800 FOR I=LN-1 TO 1 STEP -1
810 LET SX(I)=SX(I-1)
820 LET SY(I)=SY(I-1)
830 NEXT I
840 LET SX(0)=NX
850 LET SY(0)=NY

860 IF GR=0 THEN GOTO 300
870 LET LN=LN+1
880 LET SX(LN-1)=SX(LN-2)
890 LET SY(LN-1)=SY(LN-2)
891 LET SC=SC+10
892 LET FX=INT(RND*GW)
893 LET FY=INT(RND*GH)
894 GOTO 200

900 SCREEN 0
910 PRINT "GAME OVER"
920 END
