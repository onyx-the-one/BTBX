10 SCREEN 13
20 PW=4
30 PH=24
40 LX=8
50 RX=308-PW
60 LY=88
70 RY=88
80 BX=160
90 BY=100
100 DX=2
110 DY=1
120 S=0
130 K$=INKEY$
140 IF K$="Q" THEN 900
150 IF K$="A" THEN LY=LY-3
160 IF K$="Z" THEN LY=LY+3
170 IF LY<0 THEN LY=0
180 IF LY>176 THEN LY=176
190 IF BY<RY+10 THEN RY=RY-2
200 IF BY>RY+14 THEN RY=RY+2
210 IF RY<0 THEN RY=0
220 IF RY>176 THEN RY=176
230 BX=BX+DX
240 BY=BY+DY
250 IF BY<3 THEN DY=1
260 IF BY>196 THEN DY=-1
270 IF DX<0 THEN GOTO 340
280 IF BX<RX-3 THEN GOTO 520
290 IF BY<RY-3 THEN GOTO 430
300 IF BY>RY+PH+3 THEN GOTO 430
310 DX=-2
320 BX=RX-4
330 GOTO 520
340 IF BX>LX+PW+3 THEN GOTO 520
350 IF BY<LY-3 THEN GOTO 800
360 IF BY>LY+PH+3 THEN GOTO 800
370 DX=2
380 BX=LX+PW+4
390 S=S+1
400 GOTO 520
430 BX=160
440 BY=100
450 DX=-2
460 DY=1
470 GOTO 520
520 GCLS 0
530 RECT LX,LY,LX+PW,LY+PH,15,F
540 RECT RX,RY,RX+PW,RY+PH,11,F
550 CIRCLE BX,BY,3,14,F
560 RECT 0,0,S*6,3,10,F
570 FOR T=1 TO 120
580 NEXT T
590 GOTO 130
800 SCREEN 0
810 PRINT "SCORE ";S
820 PRINT "GAME OVER"
830 END
900 SCREEN 0
910 END
