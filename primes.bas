10 PRINT "PRIME STRESS TEST TO 1,000,000"
20 PRINT "COMPUTING... THIS WILL TAKE A WHILE."
30 OPEN "PRIMES.TXT" FOR OUTPUT AS 1
40 LET M = 1000000
50 LET CNT = 0
60 LET LAST = 0
70 FOR N = 2 TO M
80 LET F = 0
90 LET L = INT(SQR(N))
100 IF L < 2 THEN GOTO 150
110 FOR I = 2 TO L
120 IF MOD(N, I) = 0 THEN LET F = 1
130 IF F = 1 THEN GOTO 160
140 NEXT I
150 IF F = 0 THEN LET CNT = CNT + 1
160 IF F = 0 THEN LET LAST = N
170 NEXT N
180 PRINT "DONE."
190 PRINT "PRIMES FOUND: "; CNT
200 PRINT "LARGEST PRIME: "; LAST
210 PRINT #1, "PRIMES BELOW 1,000,000"
220 PRINT #1, CNT
230 PRINT #1, "LARGEST PRIME:"
240 PRINT #1, LAST
250 CLOSE 1
260 PRINT "RESULTS SAVED TO PRIMES.TXT"
